# Database Configuration
DATABASE_URL=sqlite:///recruitment_exam.db

# Google AI Configuration
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# N8N Configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/exam-evaluation

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Application Settings
DEBUG=False
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1

# Face Detection Settings
FACE_DETECTION_MODEL=yolo11
EVIDENCE_THRESHOLD=70
DETECTION_CONFIDENCE=0.5

# File Upload Settings
MAX_FILE_SIZE=10MB
UPLOAD_FOLDER=uploads/

# Proctoring Settings
ENABLE_FACE_DETECTION=True
ENABLE_PHONE_DETECTION=True
ENABLE_TAB_SWITCHING_DETECTION=True

# Video Recording
ENABLE_VIDEO_RECORDING=False
VIDEO_STORAGE_PATH=exam_videos/

# Frontend URL
FRONTEND_URL=http://localhost:3000 