FROM python:3.9-slim

# Install minimal system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    wget \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Upgrade pip and install wheel for faster builds
RUN pip install --upgrade pip setuptools wheel

# Copy lite requirements for faster development builds
COPY requirements-lite.txt .

# Install Python packages (lite version)
RUN pip install --no-cache-dir \
    --prefer-binary \
    -r requirements-lite.txt

# Copy application code
COPY . .

# Create directories for uploads
RUN mkdir -p /app/uploads /app/face_recognition_data /app/exam_videos /app/credentials

# Create non-root user for security
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

CMD ["uvicorn", "main_simple:app", "--host", "0.0.0.0", "--port", "8000", "--reload"] 